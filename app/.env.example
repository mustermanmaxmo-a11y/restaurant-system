# =============================================================================
# RestaurantOS — Environment-Variablen (Vorlage)
# =============================================================================
# Kopiere diese Datei nach `.env.local` und fülle die Werte aus.
# `.env.local` ist in .gitignore und wird NIEMALS committet.
# Nur Variablen-NAMEN sind hier dokumentiert — keine echten Secrets.
# Gruppiert nach Dienst; [optional] = nur nötig, wenn das Feature genutzt wird.
# =============================================================================

# --- Supabase (Pflicht: Datenbank, Auth, Realtime, Storage) ------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-Role-Key: server-only, umgeht RLS — NIE im Client verwenden.
SUPABASE_SERVICE_ROLE_KEY=

# --- App -------------------------------------------------------------------
# Öffentliche Basis-URL der App (für Links in Emails, Stripe-Redirects, Cron).
NEXT_PUBLIC_APP_URL=

# --- KI (Anthropic; Media-Gen optional) ------------------------------------
# Fallback-Key; pro Restaurant kann ein eigener Key in der DB hinterlegt sein.
ANTHROPIC_API_KEY=
FAL_API_KEY=              # [optional] Bild-/Video-Generierung
KLING_API_KEY=           # [optional] Video-Generierung

# --- Stripe (Zahlungen + Abo) ----------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CLIENT_ID=        # Stripe Connect (Auszahlungen an Restaurants)
STRIPE_PRICE_STARTER=    # Price-ID des Starter-Plans
STRIPE_PRICE_PRO=        # Price-ID des Pro-Plans

# --- Email (Resend) --------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM=             # Absenderadresse, z.B. "Name <mail@domain.de>"
EMAIL_API_SECRET=        # Schützt den internen /api/email-Endpoint

# --- Web Push (VAPID) ------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=             # mailto:-Kontakt für den Push-Dienst
PUSH_WEBHOOK_SECRET=     # Schützt den internen Push-Send-Endpoint

# --- Upstash Redis (Rate-Limiting / Cache) ---------------------------------
# Fehlt dies, fällt das Rate-Limiting auf "erlauben" zurück (nur für dev ok).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Upstash QStash (verzögerte Jobs, z.B. Bewertungs-Emails) --------------
QSTASH_TOKEN=
QSTASH_URL=              # [optional] Default: https://qstash.upstash.io
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- Sentry (Error-Monitoring) ---------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=       # [optional] nur für Sourcemap-Upload im CI/Build

# --- Secrets für Cron / Automationen / Tracking ----------------------------
CRON_SECRET=                  # schützt /api/cron/*
MARKETING_AUTOMATION_SECRET=  # schützt Marketing-Automation-Endpoints
MARKETING_TRACKING_SECRET=    # signiert Open-/Click-Tracking-Links
UNSUBSCRIBE_SECRET=           # signiert Abmelde-Links
N8N_WEBHOOK_SECRET=           # schützt n8n-Webhook-Endpoints

# --- POS-Webhooks ([optional], je nach angebundenem Kassensystem) ----------
SUMUP_WEBHOOK_SECRET=
ZETTLE_WEBHOOK_SECRET=
SQUARE_WEBHOOK_SIGNATURE_KEY=
